# Kopiere diese Datei zu .env.local (wird nicht in Git eingecheckt)
# Werte kommen aus https://sanity.io/manage → Projekt → API

NEXT_PUBLIC_SANITY_PROJECT_ID=6vse62qu
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: Read-Token für Draft-Previews
# SANITY_API_READ_TOKEN=

# Kontaktformular (Resend: https://resend.com)
# Ohne diese Variablen wird das Formular Fehler 503 zurückgeben.
# RESEND_API_KEY=re_xxxxxxxxx
# CONTACT_RECIPIENT_EMAIL=kontakt@cologne-hunters.de
# Optional: Absenderadresse (muss bei Resend verifiziert sein). Standard: onboarding@resend.dev
# CONTACT_FROM_EMAIL=no-reply@cologne-hunters.de
